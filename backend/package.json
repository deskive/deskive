{
  "name": "deskive-backend",
  "version": "1.0.0",
  "description": "Comprehensive Workspace Management Platform API",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:oauth": "jest --testPathPatterns=oauth --no-coverage --forceExit",
    "test:oauth:watch": "jest --testPathPatterns=oauth --watch --no-coverage",
    "test:integrations": "jest --testPathPatterns=integration-framework --no-coverage --forceExit",
    "setup": "ts-node scripts/setup.ts",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed-test-data.js seed",
    "seed:clear": "node scripts/seed-test-data.js clear",
    "seed:reset": "node scripts/seed-test-data.js reset"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",

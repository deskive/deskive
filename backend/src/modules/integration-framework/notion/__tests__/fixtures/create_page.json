{
  "action": "create_page",
  "baseUrl": "https://api.notion.com/v1",
  "testCases": [
    {
      "name": "creates page successfully",
      "input": {
        "parent": { "database_id": "db-123" },
        "properties": {
          "Name": {
            "title": [{ "text": { "content": "New Page" } }]
          }
        }
      },
      "mock": {
        "method": "POST",
        "path": "/pages",
        "status": 200,
        "response": {
          "id": "page-123",
          "object": "page",
          "created_time": "2024-01-01T00:00:00.000Z"
        }
      },
      "expected": {
        "success": true,
        "data": {
          "id": "page-123"
        }
      }
    }
  ]
}

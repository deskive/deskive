# =====================================================
# DESKIVE BACKEND CONFIGURATION
# =====================================================
# Copy this file to .env and update with your values
# =====================================================

# Application
PORT=3002
NODE_ENV=development
API_PREFIX=api

# Application URLs
FRONTEND_URL=http://localhost:5175
CORS_ORIGIN=http://localhost:5175,http://localhost:5173,http://localhost:3000

# =====================================================
# JWT CONFIGURATION
# =====================================================

JWT_SECRET=your_jwt_secret_min32chars_change_me
JWT_EXPIRES_IN=7d

# =====================================================
# AUTH PROVIDERS (pluggable SSO registry)
# =====================================================
# Comma-separated list of enabled auth providers. The frontend calls
# GET /api/v1/auth/providers at page-load and renders one button per
# enabled value. Unknown values are logged and ignored.
#
# Valid: local | google | github | gitlab | magic-link | keycloak | clerk | auth0
#
# `local` (email + password) is always enabled even if omitted.
# See backend/docs/providers/auth-sso.md for per-provider setup.

AUTH_PROVIDERS=local,google,github,magic-link

# --- Magic Link (passwordless email) ---
# Uses the existing SMTP_* env vars below for delivery and the
# existing JWT_SECRET for signing short-lived tokens.
MAGIC_LINK_TTL_SECONDS=900

# --- SMTP (required for magic-link, password reset, etc.) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Deskive <noreply@example.com>"
SMTP_SECURE=false

# =====================================================
# DATABASE (PostgreSQL)
# =====================================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=deskive_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=your_db_password
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# =====================================================
# REDIS CACHE
# =====================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =====================================================
# CLOUDFLARE R2 STORAGE (S3-compatible)
# =====================================================

R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=deskive-dev
R2_PUBLIC_URL=https://cdn-dev.deskive.com

# =====================================================
# =====================================================


# Stripe Price IDs

# =====================================================
# OPENAI (AI features, embeddings, transcription)
# =====================================================

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# =====================================================
# QDRANT VECTOR DATABASE
# =====================================================

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key

# =====================================================
# LIVEKIT (Video Conferencing)
# =====================================================

LIVEKIT_HOST=http://localhost:7880
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# =====================================================
# GOOGLE OAUTH
# =====================================================

GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3002/api/v1/integrations/google/callback

# =====================================================
# GITHUB OAUTH
# =====================================================

GITHUB_OAUTH_APP_ID=your_github_app_id
GITHUB_OAUTH_CLIENT_ID=your_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3002/api/v1/oauth/github/callback
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_GITHUB_APP_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_SLUG=your-github-app-slug

# =====================================================
# FIREBASE (Push Notifications)
# =====================================================

FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key":"YOUR_PRIVATE_KEY","client_email":"your-service-account@your-project.iam.gserviceaccount.com"}

# =====================================================
# GIPHY (GIF search in chat)
# =====================================================

GIPHY_API_KEY=your_giphy_api_key

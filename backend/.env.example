# =====================================================
# DESKIVE BACKEND CONFIGURATION
# =====================================================
# Copy this file to .env and update with your values
# =====================================================

# Application
PORT=3002
NODE_ENV=development
API_PREFIX=api

# Application URLs
FRONTEND_URL=http://localhost:5175
CORS_ORIGIN=http://localhost:5175,http://localhost:5173,http://localhost:3000

# =====================================================
# JWT CONFIGURATION
# =====================================================

JWT_SECRET=your_jwt_secret_min32chars_change_me
JWT_EXPIRES_IN=7d

# =====================================================
# DATABASE (PostgreSQL)
# =====================================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=deskive_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=your_db_password
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# =====================================================
# REDIS CACHE
# =====================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =====================================================
# CLOUDFLARE R2 STORAGE (S3-compatible)
# =====================================================

R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=deskive-dev
R2_PUBLIC_URL=https://cdn-dev.deskive.com

# =====================================================
# =====================================================


# Stripe Price IDs

# =====================================================
# AI PROVIDER (pluggable)
# =====================================================
# Pick a provider for text generation + embeddings + vision.
# See backend/docs/providers/ai.md for the full comparison and
# per-provider env vars.
#
# Valid values:
#   openai | anthropic | gemini | ollama | groq | none
#
# Backcompat: if AI_PROVIDER is unset but OPENAI_API_KEY is set,
# the factory defaults to "openai" so existing deployments keep
# working without touching config.

AI_PROVIDER=openai

# --- OpenAI (default) ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Ollama (local, offline) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Groq (OpenAI-compatible, ultra-fast) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# NOTE: Image generation (DALL-E), text-to-speech, and Whisper
# transcription are OpenAI-only features on AiProviderService and
# require OPENAI_API_KEY regardless of AI_PROVIDER.

# =====================================================
# QDRANT VECTOR DATABASE
# =====================================================

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key

# =====================================================
# LIVEKIT (Video Conferencing)
# =====================================================

LIVEKIT_HOST=http://localhost:7880
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# =====================================================
# GOOGLE OAUTH
# =====================================================

GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3002/api/v1/integrations/google/callback

# =====================================================
# GITHUB OAUTH
# =====================================================

GITHUB_OAUTH_APP_ID=your_github_app_id
GITHUB_OAUTH_CLIENT_ID=your_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3002/api/v1/oauth/github/callback
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_GITHUB_APP_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_SLUG=your-github-app-slug

# =====================================================
# FIREBASE (Push Notifications)
# =====================================================

FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key":"YOUR_PRIVATE_KEY","client_email":"your-service-account@your-project.iam.gserviceaccount.com"}

# =====================================================
# GIPHY (GIF search in chat)
# =====================================================

GIPHY_API_KEY=your_giphy_api_key

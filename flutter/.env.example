# =============================================================================
# DESKIVE FLUTTER - ENVIRONMENT VARIABLES EXAMPLE
# =============================================================================
# This file contains all environment variables used by the Deskive Flutter app.
# Copy this file to .env and fill in the appropriate values for your environment.
#

# =============================================================================
# APPLICATION ENVIRONMENT
# =============================================================================

# Environment mode - determines app behavior and optimizations
# Options: development, staging, production
FLUTTER_ENV=development

# Application name and version (displayed in UI)
APP_NAME=Deskive
APP_VERSION=1.0.0

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Main API base URL - backend REST API endpoint
# Development: https://api.deskive.com/api/v1
# Staging: https://api-staging.deskive.com/api/v1
# Production: https://api.deskive.com/api/v1
API_BASE_URL=https://api.deskive.com/api/v1

# WebSocket server URL for real-time features
# Development: http://localhost:3002
# Staging: https://ws-staging.deskive.com
# Production: https://ws.deskive.com
WEBSOCKET_URL=http://localhost:3002

# Web App URL for generating shareable links (join links, etc.)
# Development: http://localhost:5175
# Staging: https://staging.deskive.com
# Production: https://app.deskive.com
WEB_APP_URL=http://localhost:5175

# API request timeout in milliseconds (default: 30 seconds)
API_TIMEOUT=30000

# Maximum number of API retry attempts on failure
API_RETRY_ATTEMPTS=3

# =============================================================================
# APP AT ONCE CONFIGURATION
# =============================================================================

# App at Once API Key - service role key for server-side operations
APPATONCE_API_KEY=your_appatonce_api_key_here

# App at Once Anonymous Key - for real-time operations
APPATONCE_ANON_KEY=your_appatonce_anon_key_here

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable specific application features
# Set to 'true' to enable, 'false' to disable

# Enable debug mode (detailed logging, dev tools, etc.)
DEBUG_MODE=true

# Enable logging in console/debug output
ENABLE_LOGGING=true

# Log level - controls console output verbosity
# Options: error, warn, info, debug
LOG_LEVEL=debug

# Production flag - affects various app behaviors
IS_PRODUCTION=false

# =============================================================================
# DEFAULT VALUES (DEVELOPMENT ONLY)
# =============================================================================

# Default workspace and user IDs for development/testing
# In production, these should be empty and come from authentication
DEFAULT_WORKSPACE_ID=your_default_workspace_id_here
DEFAULT_USER_ID=your_default_user_id_here